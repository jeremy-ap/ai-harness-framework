{
  "permissions": {
    "allow": [
      "Bash(./scripts/*)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Read(*)",
      "Write(docs/*)",
      "Write(tests/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ]
  }
}
